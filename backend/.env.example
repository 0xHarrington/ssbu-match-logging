# Copy to .env for local overrides (not read automatically — export in shell
# or set via `flyctl secrets set` / fly.toml [env] in production).

# Directory holding game_results.csv and backups/ (prod: /data on the Fly volume)
DATA_DIR=.

# When set, the entire app requires HTTP Basic auth with this password.
# REQUIRED for any non-local deployment. Leave unset for local dev.
# Prod: set via `flyctl secrets set SITE_PASSWORD=...`, never in this file.
SITE_PASSWORD=

# Werkzeug debugger — dev only; must be 0 anywhere reachable from a network
FLASK_DEBUG=1

# Port for gunicorn in the container
PORT=8080
